{
  "expo": {
    "plugins": [
      "expo-system-ui",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/Gemini_Generated_Image_cdkktocdkktocdkk.png",

          "imageWidth": 200
        }
      ]
    ],
    "name": "M O V I E S",
    "slug": "movies",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Gemini_Generated_Image_cdkktocdkktocdkk.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Gemini_Generated_Image_cdkktocdkktocdkk.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.momensherif.movies"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Gemini_Generated_Image_cdkktocdkktocdkk.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.momensherif.movies"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
