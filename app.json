{
  "expo": {
    "plugins": [
      "expo-system-ui",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f1f1f1",
          "image": "./assets/icon.png",

          "imageWidth": 200
        }
      ]
    ],
    "name": "M O V I E S",
    "slug": "movies",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.momensherif.movies"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.momensherif.movies"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
